{
  "tool_name": "macro_relative_layout",
  "category": "scene",
  "mode_required": "OBJECT",
  "selection_required": false,
  "keywords": [
    "layout",
    "align",
    "place",
    "position",
    "offset",
    "contact",
    "gap",
    "corner",
    "under",
    "wyrównaj",
    "ustaw",
    "przesuń",
    "szczelina",
    "odstęp",
    "kontakt",
    "narożnik"
  ],
  "sample_prompts": [
    "place the leg under the tabletop with contact on Z",
    "align the panel to the housing and leave a small gap",
    "move this part to the top-right corner of the base",
    "ustaw nogę pod blatem z kontaktem na osi Z",
    "wyrównaj panel do obudowy i zostaw małą szczelinę",
    "przesuń ten element do prawego górnego rogu podstawy"
  ],
  "parameters": {
    "moving_object": {"type": "string", "required": true},
    "reference_object": {"type": "string", "required": true},
    "x_mode": {"type": "enum", "options": ["none", "center", "min", "max"], "default": "center"},
    "y_mode": {"type": "enum", "options": ["none", "center", "min", "max"], "default": "center"},
    "z_mode": {"type": "enum", "options": ["none", "center", "min", "max"], "default": "none"},
    "contact_axis": {"type": "enum", "options": ["X", "Y", "Z"], "default": null},
    "contact_side": {"type": "enum", "options": ["positive", "negative"], "default": "positive"},
    "gap": {"type": "float", "default": 0.0},
    "offset": {"type": "vector3", "default": [0.0, 0.0, 0.0]}
  },
  "related_tools": [
    "scene_get_bounding_box",
    "scene_measure_alignment",
    "scene_measure_gap",
    "scene_assert_contact",
    "scene_get_viewport",
    "macro_finish_form",
    "macro_cutout_recess"
  ],
  "patterns": [],
  "description": "Bounded macro that places one object relative to another using bbox alignment modes, optional outside-face contact/gap placement, and one deterministic transform. Prefer this macro over manual transform-by-transform placement when one relative layout intent matches."
}
